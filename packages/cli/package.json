{
  "name": "@bedframe/cli",
  "description": "Bedframe CLI - your Browser Extension Development framework (dev utility)",
  "author": {
    "name": "Joe Nyaggah",
    "url": "https://bedframe.dev"
  },
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "main": "dist/bedframe.js",
  "module": "dist/bedframe.js",
  "types": "dist/bedframe.d.ts",
  "exports": {
    ".": {
      "types": "./dist/bedframe.d.ts",
      "import": "./dist/bedframe.js",
      "require": "./dist/bedframe.js"
    }
  },
  "bin": {
    "bedframe": "./dist/bedframe.js",
    "create-bedframe": "./dist/create-bedframe.js"
  },
  "files": [
    "/dist",
    "/stubs",
    "package.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "pnpm clean && tsc && vite build",
    "format": "oxfmt .",
    "lint": "oxlint --fix-dangerously",
    "build:pack": "pnpm build && pnpm pack"
  },
  "dependencies": {
    "@bedframe/core": "workspace:*",
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "kolorist": "^1.8.0",
    "listr": "^0.14.3",
    "nanospinner": "^1.2.2",
    "node-fetch": "^3.3.2",
    "pkg-install": "^1.0.0",
    "prompts": "^2.4.2",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@types/chrome": "^0.1.33",
    "@types/listr": "^0.14.10",
    "@types/node": "^22.19.11",
    "@types/prompts": "^2.4.9",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.57.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --fix-dangerously"
    ],
    "*.{json,css,scss,md,mdx,html}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nyaggah/bedframe.git",
    "directory": "packages/cli"
  },
  "homepage": "https://bedframe.dev",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "concurrently": "^8.2.1"
  }
}
